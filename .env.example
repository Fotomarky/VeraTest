# --- Required ---
# Get a free key (no credit card) at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Optional ---
# SQLite database file path (default: ./simab.db)
SIMAB_DB_PATH=./simab.db

# Where uploaded images are stored on disk (default: ./uploads)
SIMAB_UPLOAD_DIR=./uploads

# Phoenix observability endpoint (if running self-hosted Phoenix)
# Default Phoenix Docker exposes 4317 for OTLP gRPC
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317

# --- Agent Builder (ADK) layer — see simab/agent.py, docs/agent-builder.md ---
# Route Gemini through Vertex AI on Google Cloud (Agent Platform).
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=veratest-497813
GOOGLE_CLOUD_LOCATION=us-central1

# Arize Phoenix MCP server target (the partner MCP server the agent calls).
# Phoenix Cloud (free): https://app.phoenix.arize.com  — or your self-hosted URL.
PHOENIX_BASE_URL=https://app.phoenix.arize.com
PHOENIX_API_KEY=

# GA4 OAuth (only needed if using GA4 connector)
# Create credentials at https://console.cloud.google.com/apis/credentials
GA4_CLIENT_ID=
GA4_CLIENT_SECRET=
GA4_REDIRECT_URI=http://localhost:8000/oauth/ga4/callback

# Frontend URL (for CORS and dashboard links)
FRONTEND_URL=http://localhost:3000

# Concurrency cap for parallel sim agents (Gemini free tier = 30 RPM, so 6 is safe)
SIMAB_SIM_CONCURRENCY=6

# Default number of scenario agents per run
SIMAB_NUM_AGENTS=20
